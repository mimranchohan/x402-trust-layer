{
  "openapi": "3.1.0",
  "info": {
    "title": "x402 Agent Suite",
    "version": "1.0.0",
    "description": "Infrastructure agents for x402: spend control, receipt audit, risk scan, API routing, research briefs. All routes return HTTP 402 until USDC payment via Dexter facilitator."
  },
  "servers": [{ "url": "http://localhost:3402" }],
  "paths": {
    "/api/spend-governor/check": {
      "post": {
        "summary": "Evaluate agent spend policy before a paid API call",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["agentId", "estimatedCostUsdc", "policy"],
                "properties": {
                  "agentId": { "type": "string" },
                  "estimatedCostUsdc": { "type": "number" },
                  "targetUrl": { "type": "string" },
                  "network": { "type": "string" },
                  "policy": {
                    "type": "object",
                    "properties": {
                      "dailyCapUsdc": { "type": "number" },
                      "perCallCapUsdc": { "type": "number" },
                      "allowedHosts": { "type": "array", "items": { "type": "string" } },
                      "blockedHosts": { "type": "array", "items": { "type": "string" } }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Allow/deny decision" }, "402": { "description": "Payment required ($0.03 USDC)" } }
      }
    },
    "/api/receipt-auditor/verify": {
      "post": {
        "summary": "Verify x402 settlement receipt or on-chain transaction",
        "responses": { "200": { "description": "Audit result" }, "402": { "description": "Payment required ($0.05 USDC)" } }
      }
    },
    "/api/risk-gate/scan": {
      "post": {
        "summary": "Probe a paid API URL and return risk score before calling",
        "responses": { "200": { "description": "Risk report" }, "402": { "description": "Payment required ($0.08 USDC)" } }
      }
    },
    "/api/router/route": {
      "post": {
        "summary": "Find best verified x402 API for a natural-language capability",
        "responses": { "200": { "description": "Router result" }, "402": { "description": "Payment required ($0.02 USDC)" } }
      }
    },
    "/api/research/brief": {
      "post": {
        "summary": "Build a paid-API research pipeline and cost estimate for a topic",
        "responses": { "200": { "description": "Brief markdown" }, "402": { "description": "Payment required ($0.20 USDC)" } }
      }
    }
  }
}
