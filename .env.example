# Server
PORT=3402
# Production: set to your custom domain so discovery/x402gle/agentic URLs are canonical
PUBLIC_BASE_URL=https://x402trustlayer.xyz
# Optional alias — used when PUBLIC_BASE_URL is unset
# CANONICAL_PUBLIC_URL=https://x402trustlayer.xyz
# Local dev fallback:
# PUBLIC_BASE_URL=http://127.0.0.1:3402

# Solana USDC receive wallet (required)
PAY_TO_ADDRESS=YourSolanaBase58Address

# Agentic.market prefers Base first — base,solana,polygon (Polygon for Agentic Wallet MCP)
NETWORKS=base,solana,polygon

# Testnet dev (Base Sepolia + Solana Devnet, x402.org facilitator)
# X402_TESTNET=1
# NETWORKS=base-sepolia,solana-devnet
# FACILITATOR_URL=https://x402.org/facilitator

# Base USDC receive wallet (required for agentic.market validation)
PAY_TO_EVM=0xYourEvmAddress

# Dexter facilitator (default — indexes Dexter / OpenDexter)
FACILITATOR_URL=https://x402.dexter.cash

# CDP Bazaar / agentic.market auto-index (requires CDP API keys on Railway)
# USE_CDP_FACILITATOR=1
# FACILITATOR_URL=https://api.cdp.coinbase.com/platform/v2/x402/facilitator
# CDP_API_KEY_ID=
# CDP_API_KEY_SECRET=

# Railway: keep facilitator + handler under proxy limit (avoid 502)
# X402_FACILITATOR_TIMEOUT_MS=45000
# PAID_REQUEST_TIMEOUT_MS=55000

# Production required — attestations (openssl rand -hex 32)
ATTESTATION_HMAC_SECRET=
# Local only: ALLOW_VERIFIER_PROBE_IDS=1 enables att_verifier_probe_example for Dexter empty-body test
# RATE_LIMIT_PER_MIN=120
# RATE_LIMIT_UNPAID_PER_MIN=600

# Demo payer only — never commit, never put on Railway
# MUST be a different wallet than PAY_TO_ADDRESS / PAY_TO_EVM (not your seller receive keys)
SOLANA_PRIVATE_KEY=
EVM_PRIVATE_KEY=

# Solana RPC for local demo / wrapFetch (Dexter default proxy can break getAccountInfo parsing)
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
# When both payer keys are set, prefer Base if NETWORKS includes base (default)
# X402_PREFERRED_NETWORK=eip155:8453

# Optional — ERC-8004 agent verify (Base mainnet reads)
# ERC8004_IDENTITY_REGISTRY=0x8004A169FB4a3325136EB29fA0ceB6D2e539a432
# ERC8004_REPUTATION_REGISTRY=0x8004BAa17C55a88189AE136b182e5fdA19dE9b63
# BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY
# ALCHEMY_API_KEY=  # optional wallet→agentId NFT lookup when agentId omitted
# TRUSTSCORE_CACHE_TTL_SEC=120
# RATE_LIMIT_AGENT_LOOKUP_PER_HOUR=30

# Optional — x402gle/Dexter "Claim host" verify (copy Value from claim UI, expires ~24h)
X402GLE_CHALLENGE_TOKEN=

# Optional — Alchemy x402 live demo (npm run demo:alchemy)
# ALCHEMY_API_KEY=  # also enables wallet→agentId lookup for POST /api/agent/verify
# ERC8004_IDENTITY_REGISTRY=0x8004A169FB4a3325136EB29fA0ceB6D2e539a432
# ERC8004_REPUTATION_REGISTRY=0x8004BAa17C55a88189AE136b182e5fdA19dE9b63
# TRUSTSCORE_CACHE_TTL_SEC=120
# RATE_LIMIT_AGENT_LOOKUP_PER_HOUR=30
# ALCHEMY_DEMO_ENTERPRISE=1
# ALCHEMY_DEMO_AGENT_ID=alchemy-live-demo-1
# ALCHEMY_DEMO_CREDIT_USDC=1
# TRUST_LAYER_BASE=https://x402trustlayer.xyz

# Trust Layer v2 — semantic escrow LLM judge (optional; heuristic fallback if unset)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_TIMEOUT_MS=25000

# KYM auto-ingest from x402watch public API (merchant-trust/score, certify)
# X402WATCH_API_BASE=https://api.x402.printmoneylab.com/api/v1
# TELEMETRY_FETCH_MS=8000

# Production webhook test dispatch (required in prod for POST /api/webhooks/test-dispatch)
# WEBHOOK_TEST_SECRET=
