# Server
PORT=3402
# Local demo: use 127.0.0.1 (not localhost) on Windows
PUBLIC_BASE_URL=http://127.0.0.1:3402

# Where USDC payments land (Solana base58 OR EVM 0x address)
PAY_TO_ADDRESS=0xYourWalletAddress

# base | solana — must match PAY_TO_ADDRESS type
NETWORK=base

# Dexter facilitator (do not change unless self-hosting)
FACILITATOR_URL=https://x402.dexter.cash

# Optional: demo client pays for your APIs
EVM_PRIVATE_KEY=
SOLANA_PRIVATE_KEY=

# Optional: Base RPC for on-chain receipt checks
BASE_RPC_URL=https://mainnet.base.org
