# Server
PORT=3402
# Production: set to your custom domain so discovery/x402gle/agentic URLs are canonical
PUBLIC_BASE_URL=https://x402trustlayer.xyz
# Optional alias — used when PUBLIC_BASE_URL is unset
# CANONICAL_PUBLIC_URL=https://x402trustlayer.xyz
# Local dev fallback:
# PUBLIC_BASE_URL=http://127.0.0.1:3402

# Solana USDC receive wallet (required)
PAY_TO_ADDRESS=YourSolanaBase58Address

# Agentic.market prefers Base first — use base,solana (not solana-only)
NETWORKS=base,solana

# Base USDC receive wallet (required for agentic.market validation)
PAY_TO_EVM=0xYourEvmAddress

# Dexter facilitator (do not change unless self-hosting)
FACILITATOR_URL=https://x402.dexter.cash

# Production required — attestations (openssl rand -hex 32)
ATTESTATION_HMAC_SECRET=
# Local only: ALLOW_VERIFIER_PROBE_IDS=1 enables att_verifier_probe_example for Dexter empty-body test
# RATE_LIMIT_PER_MIN=120
# RATE_LIMIT_UNPAID_PER_MIN=600

# Demo payer only — never commit, never put on Railway
# MUST be a different wallet than PAY_TO_ADDRESS / PAY_TO_EVM (not your seller receive keys)
SOLANA_PRIVATE_KEY=
EVM_PRIVATE_KEY=

# Solana RPC for local demo / wrapFetch (Dexter default proxy can break getAccountInfo parsing)
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
# When both payer keys are set, prefer Base if NETWORKS includes base (default)
# X402_PREFERRED_NETWORK=eip155:8453

# Optional — x402gle/Dexter "Claim host" verify (copy Value from claim UI, expires ~24h)
X402GLE_CHALLENGE_TOKEN=

# Optional
BASE_RPC_URL=https://mainnet.base.org
