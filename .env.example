# Server
PORT=3402
PUBLIC_BASE_URL=http://127.0.0.1:3402

# Solana USDC receive wallet (required)
PAY_TO_ADDRESS=YourSolanaBase58Address

# Agentic.market prefers Base first — use base,solana (not solana-only)
NETWORKS=base,solana

# Base USDC receive wallet (required for agentic.market validation)
PAY_TO_EVM=0xYourEvmAddress

# Dexter facilitator (do not change unless self-hosting)
FACILITATOR_URL=https://x402.dexter.cash

# Demo payer only — never commit, never put on Railway
SOLANA_PRIVATE_KEY=
EVM_PRIVATE_KEY=

# Optional — x402gle/Dexter "Claim host" verify (copy Value from claim UI, expires ~24h)
X402GLE_CHALLENGE_TOKEN=

# Optional
BASE_RPC_URL=https://mainnet.base.org
