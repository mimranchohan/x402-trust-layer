{
  "name": "x402-agent-suite",
  "version": "3.1.0",
  "description": "24 paid x402 infrastructure APIs for AI agent fleets — guard, proxy, MPP, attestations, multi-chain USDC",
  "type": "module",
  "author": "Mimran Chohan",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mimranchohan/x402-agent-suite.git"
  },
  "homepage": "https://x402-agent-suite-production.up.railway.app",
  "bugs": {
    "url": "https://github.com/mimranchohan/x402-agent-suite/issues"
  },
  "keywords": [
    "x402",
    "ai-agents",
    "usdc",
    "dexter",
    "micropayments",
    "solana",
    "base",
    "agentic-market"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "demo": "tsx src/client/demo.ts",
    "doctor": "tsx scripts/doctor.ts",
    "typecheck": "tsc --noEmit",
    "ci": "npm run typecheck && npm run verify:bazaar",
    "openapi:generate": "tsx scripts/generate-openapi.ts",
    "discovery:discover": "npx -y @agentcash/discovery@latest discover",
    "discovery:check": "npx -y @agentcash/discovery@latest check",
    "verify:bazaar": "tsx scripts/verify-bazaar-shape.ts",
    "audition:x402gle": "tsx scripts/run-x402gle-audition.ts",
    "probe:production": "node scripts/probe-production.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "overrides": {
    "bigint-buffer": "npm:bigint-buffer-safe@^1.1.5"
  },
  "dependencies": {
    "@dexterai/x402": "^2.0.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
